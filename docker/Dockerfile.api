# Build context = apps/api/ (Railway sets Root Directory = apps/api)
# All COPY paths are relative to apps/api/

# ── Stage 1: Build dependencies ───────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# requirements.txt is in the build context root (apps/api/requirements.txt)
COPY requirements.txt .

RUN pip install --upgrade pip && \
    pip install --no-cache-dir \
        fastapi>=0.111.0 \
        "uvicorn[standard]>=0.29.0" \
        sse-starlette>=2.1.0 \
        python-multipart>=0.0.9 \
        groq>=0.9.0 \
        openai>=1.30.0 \
        aiohttp>=3.9.0 \
        anyio>=4.0.0 \
        tenacity>=8.3.0 \
        redis>=5.0.0 \
        fakeredis>=2.21.0 \
        sentence-transformers>=3.0.0 \
        "faiss-cpu>=1.8.0" \
        duckduckgo-search>=6.0.0 \
        vaderSentiment>=3.3.2 \
        nltk>=3.8.0 \
        spacy>=3.7.0 \
        pydantic>=2.7.0 \
        "pydantic-settings>=2.0.0" \
        python-dotenv>=1.0.0 \
        pyyaml>=6.0.0 \
        omegaconf>=2.3.0 \
        "presidio-analyzer>=2.2.0" \
        "presidio-anonymizer>=2.2.0" \
        structlog>=24.0.0 \
        rich>=13.7.0 \
        httpx>=0.27.0 \
        "numpy>=1.26.0" \
        rank-bm25>=0.2.2

# Download spacy model
RUN python -m spacy download en_core_web_sm

# Download NLTK data
RUN python -c "import nltk; nltk.download('vader_lexicon'); nltk.download('punkt'); nltk.download('stopwords')"

# ── Stage 2: Runtime image ─────────────────────────────────────────────────────
FROM python:3.12-slim AS runtime

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.12 /usr/local/lib/python3.12
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy ALL app source (build context = apps/api/)
COPY . .

# Create runtime directories
RUN mkdir -p data/kb/faiss data/kb/text logs

# Run as non-root
RUN useradd -m -u 1000 achp && chown -R achp:achp /app
USER achp

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "main:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--workers", "1", \
     "--log-level", "info"]
