# ── LLM Providers ──────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Get keys at:
#   Groq:       https://console.groq.com/keys
#   OpenRouter: https://openrouter.ai/settings/keys

# ── Models ──────────────────────────────────────────────────────────────────
PROPOSER_MODEL=meta-llama/llama-4-scout
ADVERSARY_A_MODEL=deepseek/deepseek-r1
ADVERSARY_B_MODEL=qwen/qwen-32b-instruct
JUDGE_MODEL=deepseek/deepseek-chat
PERSPECTIVE_MODEL=mistralai/mixtral-8x7b-instruct
JUDGE_FALLBACK_MODEL=mistralai/mixtral-8x7b-instruct

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
USE_FAKEREDIS=true          # Set false in production with real Redis

# ── Semantic Cache ──────────────────────────────────────────────────────────
CACHE_COSINE_THRESHOLD=0.85         # Tier 1 similarity threshold
CACHE_CROSS_ENCODER_THRESHOLD=0.65  # Tier 2 cross-encoder gate
CACHE_LLM_VALIDATION=true           # Enable Tier 3 LLM validation
CACHE_TTL_SECONDS=3600              # 1 hour default TTL

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
ACHP_LOG_LEVEL=INFO
